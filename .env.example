# ─── Backend (NestJS) ───────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3000

# URL interna hacia el microservicio de IA
AI_SERVICE_URL=http://localhost:8000

# Límite de tamaño de archivo (en bytes, 10MB)
MAX_FILE_SIZE=10485760

# JWT (generar secretos fuertes en producción: openssl rand -hex 32)
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min

# ─── AI Service (FastAPI/Python) ────────────────────────────────────
AI_SERVICE_PORT=8000
MODEL_PATH=./models/model.pth
MODEL_VERSION=v1.0.0

# ─── Frontend (Vite) ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000
